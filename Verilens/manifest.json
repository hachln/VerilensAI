{
  "manifest_version": 3,
  "name": "VeriLens: AI Fact Checker",
  "version": "1.0",
  "description": "Right-click an image or video to fact-check its origins using AI.",
  "permissions": [
    "contextMenus",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "all_frames": true
    }
  ],
  "action": {
    "default_title": "VeriLens Fact Check",
    "default_icon": "verilenslogo.png"
  },
  "icons": {"16": "verilenslogo.png"}
}